<div class="container mt-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="display-4">
      <i class="fas fa-film me-2 text-primary"></i>
      My Movie Lists
    </h1>
    <%= link_to new_list_path, class: 'btn btn-primary btn-lg' do %>
      <i class="fas fa-plus me-2"></i> Create New List
    <% end %>
  </div>

  <% if @lists.empty? %>
    <div class="text-center py-5">
      <i class="fas fa-folder-open fa-4x text-muted mb-3"></i>
      <h3 class="text-muted">No lists yet</h3>
      <p class="mb-4">Start by creating your first movie list!</p>
      <%= link_to new_list_path, class: 'btn btn-primary' do %>
        <i class="fas fa-plus me-2"></i> Create your first list
      <% end %>
    </div>
  <% else %>
    <div class="row">
      <% @lists.each do |list| %>
        <div class="col-md-4 mb-4">
          <div class="card h-100 shadow-sm list-card border-0">
            <%= link_to list_path(list), class: 'text-decoration-none' do %>
              <% if list.photo.attached? %>
                <div class="position-relative" style="height: 200px; overflow: hidden;">
                  <%= cl_image_tag list.photo.key,
                      class: "card-img-top",
                      style: "width: 100%; height: 100%; object-fit: cover;",
                      alt: list.name,
                      crop: :fill,
                      gravity: :auto %>
                  <div class="position-absolute top-0 end-0 m-2">
                    <span class="badge bg-primary">
                      <i class="fas fa-film me-1"></i>
                      <%= pluralize(list.movies.count, 'movie') %>
                    </span>
                  </div>
                </div>
              <% else %>
                <div class="bg-gradient" style="height: 200px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                  <div class="d-flex align-items-center justify-content-center h-100">
                    <div class="text-center text-white">
                      <i class="fas fa-camera fa-3x mb-2"></i>
                      <p class="mb-0 fw-light">No cover yet</p>
                    </div>
                  </div>
                </div>
              <% end %>

              <div class="card-body">
                <h5 class="card-title text-dark fw-bold mb-2"><%= list.name %></h5>
                <p class="card-text text-muted small mb-0">
                  <i class="fas fa-clock me-1"></i>
                  Created <%= time_ago_in_words(list.created_at) %> ago
                </p>
              </div>
            <% end %>

            <div class="card-footer bg-transparent border-0 d-flex justify-content-end pt-0">
              <%= button_to list_path(list), method: :delete,
                  class: 'btn btn-outline-danger btn-sm rounded-pill',
                  form: { data: { turbo_confirm: 'Are you sure you want to delete this list?' } } do %>
                <i class="fas fa-trash me-1"></i> Delete
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
